# git-ai-commit: environment variables for remote LLM providers
#
# Provider is auto-detected from whichever of these is set (priority order):
#   openrouter > openai > anthropic > minimax
# If none is set, the script falls back to local Ollama.
#
# Any single key is enough — set just the one you actually use.
# To force a specific provider regardless of env, pass --provider NAME.

# --- API keys (at least one is required for a non-ollama provider) ---

# OpenRouter (https://openrouter.ai/keys) — aggregator, any model
# OPENROUTER_API_KEY=sk-or-v1-...

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-...

# Anthropic (https://console.anthropic.com/)
# ANTHROPIC_API_KEY=sk-ant-...

# MiniMax (https://platform.minimax.io/)
# MINIMAX_API_KEY=eyJ...

# --- Per-provider model overrides (optional) ---
# Each <PROVIDER>_MODEL beats the per-provider default.
# GAIC_MODEL is a universal override that beats them all.
# CLI --model still wins over everything.

# OPENAI_MODEL=gpt-4o
# OPENROUTER_MODEL=anthropic/claude-3.5-haiku
# ANTHROPIC_MODEL=claude-sonnet-4-5
# MINIMAX_MODEL=MiniMax-M3
# OLLAMA_MODEL=mistral-nemo:latest
# GAIC_MODEL=gpt-4o-mini

# --- Tagging behavior ---
# ALWAYS_TAG=1 makes `git-ai-commit` (no flag) bump and push the next semver
# tag after every successful commit — same as passing `--tag` by default.
# Accepted values: 0|1|true|false|yes|no|on|off (default: 0).
# CLI --tag still wins for a single run.
# ALWAYS_TAG=0

# --- HTTP tuning ---
# CURL_TIMEOUT        per-request timeout in seconds (default: 60)
# CURL_CONN_TIMEOUT   TCP connect timeout in seconds (default: 5)
# CURL_RETRIES        retries on 5xx / transport errors (default: 2)
# CURL_RETRY_DELAY    initial delay between retries in seconds (default: 1)
# CURL_RETRY_BACKOFF  multiplier applied to the delay after each retry (default: 2)
# CURL_TIMEOUT=60
# CURL_CONN_TIMEOUT=5
# CURL_RETRIES=2
# CURL_RETRY_DELAY=1
# CURL_RETRY_BACKOFF=2

# --- Ollama reachability probe ---
# Used to decide whether to fall back to push-only mode.
# OLLAMA_PROBE_CONNECT_TIMEOUT=1
# OLLAMA_PROBE_TIMEOUT=2

# --- Message length caps ---
# MAX_COMMIT_MESSAGE_LENGTH  target length for the primary prompt (default: 500).
#                            Longer LLM responses are truncated to this before commit.
# MAX_SIMPLE_MESSAGE_LENGTH  target length for the Ollama fallback prompt (default: 1000).
# MAX_COMMIT_MESSAGE_LENGTH=500
# MAX_SIMPLE_MESSAGE_LENGTH=1000

# --- LLM prompt templates ---
# Each template takes two %s placeholders: max length and the full diff
# (verbatim — including all hunks). Override to steer the model's
# wording without editing source. The --lang flag is currently a no-op
# (no separate per-language template); only these two strings exist.
# PROMPT_TEMPLATE='Generate only a commit message (max %s chars) in English for the following diff: %s. Reply with only the message, no extra text.'
# PROMPT_FALLBACK_TEMPLATE='Only commit message (under %s chars): %s'

# --- Semver tag pattern ---
# Regex used to identify semver tags when computing the next bump.
# Default: ^v[0-9]+\.[0-9]+\.[0-9]+$
# SEMVER_TAG_PATTERN='^v[0-9]+\.[0-9]+\.[0-9]+$'

