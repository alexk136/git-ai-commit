# Sample per-repo config for git-ai-commit.
# Drop this file at the root of a repository as `.gitaicommit`
# (or symlink to a shared location).
#
# Precedence (highest → lowest):
#   CLI flag > <PROVIDER>_MODEL / GAIC_MODEL env > this file > ~/.config/git-ai-commit/config > built-in defaults

# LLM provider: ollama | openai | openrouter | anthropic | minimax
# (Leave commented out to auto-detect from env API keys.)
# PROVIDER=openai

# Model name (provider-specific default is used if omitted)
# MODEL=gpt-4o-mini

# Custom API endpoint (e.g. for proxies, self-hosted gateways, regional mirrors)
# BASE_URL=https://api.openai.com/v1

# Inline API key (overrides <PROVIDER>_API_KEY env var)
# API_KEY=sk-...

# Version bump: patch (default) | minor | major
# BUMP=patch

# Always bump and push a semver tag after every commit (0|1, default: 0).
# Equivalent to passing --tag on every invocation, but settable per-repo.
# ALWAYS_TAG=0

# Commit message language: english (default) | russian
# LANG=english

# Max commit message length (default: 500; longer messages are truncated)
# MAX_COMMIT_MESSAGE_LENGTH=500

# Max length for the simpler fallback prompt used only by Ollama (default: 1000)
# MAX_SIMPLE_MESSAGE_LENGTH=1000

# HTTP timeout in seconds (default: 60)
# CURL_TIMEOUT=60

# Number of retries on 5xx / transport errors (default: 2)
# CURL_RETRIES=2

# Initial retry delay in seconds (default: 1)
# CURL_RETRY_DELAY=1

# Multiplier applied to the retry delay after each attempt (default: 2)
# CURL_RETRY_BACKOFF=2

# TCP connect timeout in seconds (default: 5)
# CURL_CONN_TIMEOUT=5

# Ollama reachability probe (seconds). Used to decide push-only fallback.
# OLLAMA_PROBE_CONNECT_TIMEOUT=1
# OLLAMA_PROBE_TIMEOUT=2

# LLM prompt templates. Two %s placeholders: max length, full diff.
# PROMPT_TEMPLATE='Generate only a commit message (max %s chars) in English for the following diff: %s. Reply with only the message, no extra text.'
# PROMPT_FALLBACK_TEMPLATE='Only commit message (under %s chars): %s'

# Semver regex used when computing the next tag (default ^v\d+\.\d+\.\d+$).
# SEMVER_TAG_PATTERN='^v[0-9]+\.[0-9]+\.[0-9]+$'
